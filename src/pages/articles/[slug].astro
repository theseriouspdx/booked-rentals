---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const articles = await getCollection('articles', ({ data }) => data.draft !== true);
    return articles.map(article => ({
        params: { slug: article.id },
        props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const tagClass = (() => {
    switch (article.data.category) {
        case 'Guest Management': return 'tag-teal';
        case 'Legal & Insurance': return 'tag-pink';
        default: return 'tag-purple';
    }
})();

const formattedDate = article.data.date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});
---

<BaseLayout title={`${article.data.title} - booked.rentals`} description={article.data.excerpt}>
    <div class="content-page-header">
        <div class="container">
            <div class={`article-tag ${tagClass}`}>{article.data.category}</div>
            <h1>{article.data.title}</h1>
            <time>{formattedDate}</time>
        </div>
    </div>
    <section>
        <div class="container">
            {article.data.image && (
                <img src={article.data.image} alt={article.data.title} style="max-width: 100%; height: auto; border-radius: 8px; margin-bottom: 2rem;">
            )}
            <div class="prose">
                <Content />
            </div>
            <div class="prose">
                <a href="/articles/" class="back-link">← Back to Articles</a>
            </div>
        </div>
    </section>
</BaseLayout>
