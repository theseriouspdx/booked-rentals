---
interface Props {
    title: string;
    date: Date;
    excerpt: string;
    slug: string;
}

const { title, date, excerpt, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});
---

<article class="news-card">
    <time class="news-date">{formattedDate}</time>
    <h3>{title}</h3>
    <p>{excerpt}</p>
    <a href={`/news/${slug}/`} class="read-more">Read More →</a>
</article>
