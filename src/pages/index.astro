---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ProductCard from '../components/ProductCard.astro';
import NewsCard from '../components/NewsCard.astro';
import EmailForm from '../components/EmailForm.astro';
import { getCollection } from 'astro:content';

// Query content collections
const allArticles = await getCollection('articles', ({ data }) => data.draft !== true);
const featuredArticles = allArticles.filter(a => a.data.featured);
const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter(p => p.data.featured);
const allNews = await getCollection('news', ({ data }) => data.draft !== true);
const latestNews = allNews.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 2);

// Fallback data if collections are empty
const fallbackArticles = [
    { id: 'first-one-star-review', data: { title: "Your First 1-Star Review: A Superhost's Survival Guide", excerpt: "It's going to happen. Even with a perfect setup and five-star communication, someone will leave you a one-star review. Here's how to respond without losing your mind or your ranking.", category: 'Guest Management' } },
    { id: 'aircover-claims', data: { title: "How AirCover Actually Works (From Someone Who's Filed Claims)", excerpt: "Airbnb's damage protection sounds great in the marketing. The reality is more complicated. Here's what's actually covered, what isn't, and how to file a claim that gets paid.", category: 'Legal & Insurance' } },
    { id: 'nightmare-guest-scenarios', data: { title: "7 Nightmare Guest Scenarios and Exactly How to Handle Each", excerpt: "From the guest who throws a party to the one who ghosts on checkout day. Real scenarios from real hosting, with step-by-step playbooks for each one.", category: 'Guest Management' } },
];

const fallbackNews = [
    { id: 'airbnb-spring-2026-update', data: { title: "Airbnb's Spring 2026 Update: What Hosts Need to Know", date: new Date('2026-03-28'), excerpt: "The latest platform changes affect search ranking, pricing tools, and guest communication. Here's the breakdown." } },
    { id: 'str-regulations-tracker', data: { title: 'New STR Regulations: A State-by-State Tracker', date: new Date('2026-03-15'), excerpt: "Short-term rental laws are changing fast. We're tracking the updates that matter for hosts in every major market." } },
];

const displayArticles = featuredArticles.length > 0 ? featuredArticles : fallbackArticles;
const displayNews = latestNews.length > 0 ? latestNews : fallbackNews;
---

<BaseLayout title="booked.rentals - Smart Hosting for Superhosts">

    <!-- Header Banner — occupancy tracker image with logo overlay -->
    <section class="header-banner" id="header-banner">
        <img src="/images/booked-header.png" alt="booked.rentals Superhost occupancy tracker showing consistent 78-94% occupancy rates across 16 quarters from 2022 to 2025" class="header-banner-img">
        <div class="header-banner-overlay">
            <div class="header-banner-logo">
                <div class="logo-icon-box logo-icon-box--large">
                    <svg width="32" height="32" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M2 6L8 2L14 6V12C14 12.5304 13.7893 13.0391 13.4142 13.4142C13.0391 13.7893 12.5304 14 12 14H4C3.46957 14 2.96086 13.7893 2.58579 13.4142C2.21071 13.0391 2 12.5304 2 12V6Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M6 14V8H10V14" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="logo-text"><span class="logo-white">booked</span><span class="logo-teal">.rentals</span></span>
            </div>
            <p class="header-banner-tagline">stay booked.rentals means you're <em class="gradient-text">always booked</em></p>
        </div>
    </section>

    <!-- Hero Section -->
    <section class="hero" id="hero">
        <div class="container">
            <div class="hero-badge">From a 16x Superhost with 315+ Five-Star Reviews</div>
            <h1 class="hero-title">Smart hosting starts with<br><em>real experience</em></h1>
            <p class="hero-subtitle">Strategies, automation, and guides for short-term rental hosts who want higher ratings, better guests, and less time on the grind.</p>
            <EmailForm id="heroForm" buttonText="Get Early Access" />
            <p class="hero-disclaimer">Be first to know when we launch. No spam, ever.</p>
        </div>
    </section>

    <!-- Featured Articles -->
    <section class="featured-articles" id="articles">
        <div class="container">
            <h2 class="section-title">Featured Articles</h2>
            <div class="articles-grid">
                {displayArticles.map(article => (
                    <ArticleCard
                        title={article.data.title}
                        excerpt={article.data.excerpt}
                        category={article.data.category}
                        slug={article.id}
                    />
                ))}
            </div>
        </div>
    </section>

    <!-- Content Categories -->
    <section class="categories" id="categories">
        <div class="container">
            <h2 class="section-title">Explore Topics</h2>
            <div class="categories-grid">
                <div class="category-card">
                    <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    <h3>Guest Management</h3>
                    <p>Communication templates, conflict resolution, and review strategies.</p>
                    <span class="article-count">12 articles</span>
                </div>
                <div class="category-card">
                    <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                    </svg>
                    <h3>Pricing & Revenue</h3>
                    <p>Dynamic pricing, seasonal strategy, and revenue optimization.</p>
                    <span class="article-count">8 articles</span>
                </div>
                <div class="category-card">
                    <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    <h3>Automation & Tools</h3>
                    <p>Smart home tech, messaging automation, and operational systems.</p>
                    <span class="article-count">10 articles</span>
                </div>
                <div class="category-card">
                    <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    <h3>Property Setup</h3>
                    <p>Design, amenities, listings, and first impressions that convert.</p>
                    <span class="article-count">9 articles</span>
                </div>
                <div class="category-card">
                    <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    <h3>Reviews & Ratings</h3>
                    <p>Getting five stars consistently and handling the ones that aren't.</p>
                    <span class="article-count">7 articles</span>
                </div>
                <div class="category-card">
                    <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                    <h3>Legal & Insurance</h3>
                    <p>AirCover, liability, local regulations, and protecting your asset.</p>
                    <span class="article-count">6 articles</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Email Capture -->
    <section class="email-capture" id="cta-guide">
        <div class="container">
            <h2>Get the guide that 5-star hosts swear by</h2>
            <p>Join 2,000+ Superhosts who've already leveled up their hosting game</p>
            <EmailForm id="captureForm" buttonText="Get the Guide" placeholder="Enter your email" large={true} />
        </div>
    </section>

    <!-- Products -->
    <section class="products" id="products">
        <div class="container">
            <h2 class="section-title">Products We Actually Use</h2>
            <p class="section-subtitle">Every recommendation is something installed in our own rental. No pay-to-play.</p>
            <div class="products-grid">
                {featuredProducts.length > 0 ? (
                    featuredProducts.map(product => (
                        <ProductCard
                            title={product.data.title}
                            review={product.data.review}
                            rating={product.data.rating}
                            slug={product.id}
                        />
                    ))
                ) : (
                    <>
                        <div class="product-card">
                            <div class="product-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <rect x="3" y="11" width="18" height="11" rx="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                            </div>
                            <h3>Smart Lock</h3>
                            <p>Keyless entry that eliminated 90% of our check-in messages.</p>
                            <div class="product-rating">
                                <span class="stars">★★★★★</span>
                                <span class="rating-text">4.9 (342 reviews)</span>
                            </div>
                        </div>
                        <div class="product-card">
                            <div class="product-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <line x1="12" y1="1" x2="12" y2="23"></line>
                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                                </svg>
                            </div>
                            <h3>Dynamic Pricing Tool</h3>
                            <p>Set it and forget it pricing that boosted our revenue 23%.</p>
                            <div class="product-rating">
                                <span class="stars">★★★★★</span>
                                <span class="rating-text">4.8 (289 reviews)</span>
                            </div>
                        </div>
                        <div class="product-card">
                            <div class="product-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path d="M12 1a11 11 0 0 1 11 11v3h-2v-3a9 9 0 1 0-9 9"></path>
                                    <polyline points="12 5 12 12 16 16"></polyline>
                                </svg>
                            </div>
                            <h3>Noise Monitor</h3>
                            <p>Peace of mind without invading guest privacy.</p>
                            <div class="product-rating">
                                <span class="stars">★★★★★</span>
                                <span class="rating-text">4.7 (156 reviews)</span>
                            </div>
                        </div>
                    </>
                )}
            </div>
        </div>
    </section>

    <!-- News -->
    <section class="news" id="news">
        <div class="container">
            <h2 class="section-title">Latest News</h2>
            <div class="news-grid">
                {displayNews.map(item => (
                    <NewsCard
                        title={item.data.title}
                        date={item.data.date}
                        excerpt={item.data.excerpt}
                        slug={item.id}
                    />
                ))}
            </div>
        </div>
    </section>

    <!-- AlwaysBooked University -->
    <section class="university" id="university">
        <div class="container">
            <div class="university-card">
                <h2>AlwaysBooked University</h2>
                <p>Master-level courses, certification programs, and mentorship from top Superhosts</p>
                <p class="university-tagline">Courses, templates, and systems from hosts who've done it. Not gurus who've googled it.</p>
                <div class="university-status">Coming Soon</div>
                <button class="btn btn-outline">Join the Waitlist</button>
            </div>
        </div>
    </section>

</BaseLayout>
