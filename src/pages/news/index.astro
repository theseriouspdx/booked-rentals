---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const news = await getCollection('news', ({ data }) => data.draft !== true);
const sortedNews = news.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="News - booked.rentals" description="The latest updates, regulation changes, and platform news that matter for short-term rental hosts.">
    <div class="listing-header">
        <div class="container">
            <h1>Latest News</h1>
            <p>Platform updates, regulation changes, and industry news that matter for hosts.</p>
        </div>
    </div>
    <section>
        <div class="container">
            <div class="news-grid">
                {sortedNews.map(item => (
                    <NewsCard
                        title={item.data.title}
                        date={item.data.date}
                        excerpt={item.data.excerpt}
                        slug={item.id}
                    />
                ))}
            </div>
        </div>
    </section>
</BaseLayout>
